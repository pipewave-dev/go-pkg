{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  // Predefined variables https://code.visualstudio.com/docs/editor/variables-reference
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch playground",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/playground",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Launch main",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Run public-server",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}",
      "cwd": "${workspaceFolder}",
      "args": ["server", "public"]
    },
    {
      "name": "Debug task",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}",
      "cwd": "${workspaceFolder}",
      "args": ["task", "example", "hello_v1"]
    }
  ]
}
